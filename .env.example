# --- Sanity (CMS) ---
# Create a free project at https://www.sanity.io/manage and copy the project ID.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01

# Required only for the seed script (`npm run sanity:seed`) and any future
# write operations. Create at https://www.sanity.io/manage → API → Tokens
# with "Editor" or "Deploy Studio" permissions. Keep secret — don't commit.
SANITY_WRITE_TOKEN=

# --- Forms (Resend) ---
# Sign up at https://resend.com, verify your domain, create an API key.
RESEND_API_KEY=

# Comma-separated list of recipients for contact + subscribe forms.
NOTIFY_EMAILS=aubrey@example.com,chris@ravenpmg.com

# Verified "from" address — must match a domain you've verified in Resend.
NOTIFY_FROM=Trout House <noreply@trouthousetahoe.com>

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://trouthousetahoe.com
